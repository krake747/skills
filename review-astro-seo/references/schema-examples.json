{
  "Article": {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Your Post Title",
    "description": "Your post excerpt",
    "image": {
      "@type": "ImageObject",
      "url": "https://your-site.com/hero-image.jpg",
      "width": 1200,
      "height": 630
    },
    "datePublished": "2024-01-15",
    "dateModified": "2024-01-15",
    "author": { "@type": "Person", "name": "Your Name", "url": "https://your-site.com/about" },
    "publisher": {
      "@type": "Organization",
      "name": "Your Site",
      "logo": {
        "@type": "ImageObject",
        "url": "https://your-site.com/logo.png",
        "width": 600,
        "height": 60
      }
    },
    "mainEntityOfPage": "https://your-site.com/your-post",
    "wordCount": 1234
  },
  "Person": {
    "@type": "Person",
    "name": "Your Name",
    "url": "https://your-site.com/about",
    "image": "https://your-site.com/your-photo.jpg",
    "jobTitle": "Your Job Title",
    "worksFor": { "@type": "Organization", "name": "Your Company" },
    "sameAs": ["https://twitter.com/yourhandle", "https://linkedin.com/in/yourprofile"]
  },
  "BreadcrumbList": {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://your-site.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://your-site.com/blog" },
      { "@type": "ListItem", "position": 3, "name": "Your Post Title" }
    ]
  },
  "HowTo": {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Add Pagefind to Astro",
    "totalTime": "PT1H",
    "step": [
      {
        "@type": "HowToStep",
        "position": 1,
        "name": "Install Pagefind",
        "text": "Run npm install --save-dev pagefind"
      },
      {
        "@type": "HowToStep",
        "position": 2,
        "name": "Configure postbuild",
        "text": "Add postbuild script to package.json"
      },
      {
        "@type": "HowToStep",
        "position": 3,
        "name": "Mark content",
        "text": "Add data-pagefind-body to article elements"
      },
      {
        "@type": "HowToStep",
        "position": 4,
        "name": "Build search page",
        "text": "Create /search page with Pagefind UI"
      }
    ]
  },
  "SearchAction": {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "https://your-site.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://your-site.com/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
}
